<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
  <apiVersion>66.0</apiVersion>
  <isExposed>true</isExposed>
  <masterLabel>Program Benefit Manager</masterLabel>
  <description>Program Services workspace. Lets Program Managers view, add, replace, and retire Benefits for a Program without touching raw Salesforce records. Feeds Census and Interview resolvers.</description>
  <targets>
    <target>lightning__AppPage</target>
    <target>lightning__RecordPage</target>
  </targets>
  <targetConfigs>
    <targetConfig targets="lightning__RecordPage">
      <objects>
        <object>Program</object>
      </objects>
      <supportedFormFactors>
        <supportedFormFactor type="Large"/>
      </supportedFormFactors>
    </targetConfig>
    <targetConfig targets="lightning__AppPage">
      <supportedFormFactors>
        <supportedFormFactor type="Large"/>
      </supportedFormFactors>
    </targetConfig>
  </targetConfigs>
</LightningComponentBundle>
